{
  "name": "mail-time",
  "version": "4.0.0",
  "description": "📮 Email queue extending nodemailer with multi-SMTP transports and horizontally scaled apps support",
  "main": "index.js",
  "types": "./index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./index.d.ts",
        "default": "./index.js"
      },
      "require": {
        "types": "./index.d.cts",
        "default": "./index.cjs"
      }
    },
    "./presets": {
      "import": {
        "types": "./presets.d.ts",
        "default": "./presets.js"
      }
    },
    "./adapters/mongo": {
      "import": {
        "types": "./adapters/mongo.d.ts",
        "default": "./adapters/mongo.js"
      }
    },
    "./adapters/redis": {
      "import": {
        "types": "./adapters/redis.d.ts",
        "default": "./adapters/redis.js"
      }
    },
    "./adapters/postgres": {
      "import": {
        "types": "./adapters/postgres.d.ts",
        "default": "./adapters/postgres.js"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "prepublishOnly": "rollup --config rollup.config.js && rm -rf ./.types-tmp && tsc --emitDeclarationOnly --declaration --outDir ./.types-tmp --rootDir ./ && node ./scripts/strip-internal-dts.mjs ./.types-tmp/index.d.ts ./.types-tmp/presets.d.ts ./.types-tmp/adapters/mongo.d.ts ./.types-tmp/adapters/redis.d.ts ./.types-tmp/adapters/postgres.d.ts && cp ./.types-tmp/index.d.ts ./index.d.ts && cp ./.types-tmp/index.d.ts ./index.d.cts && cp ./.types-tmp/presets.d.ts ./presets.d.ts && cp ./.types-tmp/adapters/*.d.ts ./adapters/ && rm -rf ./.types-tmp",
    "test": "npm run test:jest && npm run test:mocha && npm run test:types",
    "test:jest": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --config jest.config.mjs",
    "test:mocha": "mocha ./test/npm.js",
    "test:types": "tsc -p ./tsconfig.types.json",
    "test:redis": "mocha ./test/npm-redis-redis.js",
    "test:mongo": "mocha ./test/npm-mongo-mongo.js",
    "test:postgres": "mocha ./test/npm-postgres.js",
    "test:bun": "bun test ./test/jest"
  },
  "keywords": [
    "backup",
    "balanced",
    "balancer",
    "bulletproof",
    "bun",
    "cluster",
    "email",
    "highload",
    "high load",
    "horizontal scaling",
    "mail",
    "mail-time",
    "mailer",
    "mailtime",
    "microservice",
    "micro-service",
    "nodemailer",
    "postgres",
    "queue",
    "scheduler",
    "template"
  ],
  "tags": [
    "backup",
    "balanced",
    "balancer",
    "bulletproof",
    "bun",
    "cluster",
    "email",
    "highload",
    "high load",
    "horizontal scaling",
    "mail",
    "mail-time",
    "mailer",
    "mailtime",
    "microservice",
    "micro-service",
    "nodemailer",
    "postgres",
    "queue",
    "scheduler",
    "template"
  ],
  "repository": {
    "type": "git",
    "url": "git://github.com/veliovgroup/mail-time.git"
  },
  "bugs": {
    "url": "https://github.com/veliovgroup/mail-time/issues"
  },
  "homepage": "https://github.com/veliovgroup/mail-time",
  "author": "dr.dimitru (https://veliovgroup.com)",
  "license": "BSD-3-Clause",
  "engines": {
    "node": ">=20.9.0"
  },
  "dependencies": {
    "josk": "^6.0.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "@types/node": "^25.8.0",
    "chai": "^6.2.2",
    "jest": "^30.4.2",
    "mocha": "^11.7.5",
    "mongodb": "^6.21.0",
    "nodemailer": "^8.0.7",
    "pg": "^8.20.0",
    "redis": "^5.12.1",
    "rollup": "^4.60.4",
    "typescript": "^6.0.3"
  }
}
